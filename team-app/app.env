# 鹰眼 · 容器运行时环境（compose 中 app 服务）
APP_PORT=8080
PORT=8080

# 竞赛模板标准（PostgreSQL；容器内主机名用 db）
DATABASE_URL=postgres://app:demo-password@db:5432/app

# 确定性引擎演示（不依赖外网 LLM / Supabase）
RAG_ENABLED=false
RAG_MODE=json

# 可选：接入同 compose 内的 L1 sidecar 时取消注释并增加 l1-parser 服务
# PPSTRUCTURE_URL=http://l1-parser:8787

# 可选：LLM 密钥（医保内网离线环境通常留空）
# MINIMAX_API_KEY=
# ANTHROPIC_API_KEY=
