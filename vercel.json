{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd prototype/app && npm ci",
  "buildCommand": "cd prototype/app && npm run build:rules",
  "outputDirectory": "prototype/app/public",
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "prototype/data/**,prototype/docs/**,yhf/**,docs/**,eval/**,assets/**,prompts/**"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/brand/gpt-v2/:path*", "destination": "/api" }
  ]
}
