{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "cd prototype/app && npm ci",
  "buildCommand": "node scripts/prepare-vercel.mjs",
  "outputDirectory": "prototype/app/public",
  "functions": {
    "api/index.js": {
      "maxDuration": 60,
      "includeFiles": "prototype/**,yhf/**,docs/**,eval/**,assets/**,prompts/**,scripts/verify-vercel-bundle.mjs"
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/brand/gpt-v2/:path*", "destination": "/api" }
  ]
}
