# 鹰眼 · 本地密钥（不进 git，见 .gitignore）
# 复制为 .env 并填入真实值

# --- MiniMax（稽核 LLM / 多模态）---
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
YINGYAN_LLM_MODEL=MiniMax-Text-01
YINGYAN_VL_MODEL=abab6.5s-chat

# --- Route B · Supabase（结构化 KB + pgvector）---
# 本地开发：运行 `supabase start` 后把 status 里的 URL/keys 贴过来
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# --- 阶跃星辰（Vector Store 语义层；OpenAI 兼容）---
# 开放平台 https://platform.stepfun.com → 接口密钥
STEPFUN_API_KEY=
# STEP_API_KEY=   # 与 STEPFUN_API_KEY 二选一
STEPFUN_BASE_URL=https://api.stepfun.com/v1
STEPFUN_VECTOR_STORE_NAME=yingyan-kb
# STEPFUN_VECTOR_STORE_ID=   # 首次 ingest --stepfun 后自动创建，可写回此处

# --- RAG 开关 ---
RAG_ENABLED=true
RAG_MODE=auto
RAG_CORPUS_VERSION=2026.06.15-v1

# --- RAGFlow（PDF 解析，Route B 可选）---
# RAGFLOW_URL=http://127.0.0.1:9380
# RAGFLOW_API_KEY=
